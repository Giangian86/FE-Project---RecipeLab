{
  "name": "recipelab",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run api\" \"npm run dev\"",
    "dev": "vite --host 127.0.0.1",
    "api": "json-server --watch db.json --host 127.0.0.1 --port 3001",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.0",
    "bootstrap": "^5.3.8",
    "json-server": "^0.17.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.0",
    "vite": "^6.0.7"
  }
}
